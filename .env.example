# Supabase Edge Function secrets
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Frontend public Supabase client settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key
# Set true only for the local test mode; production must use Supabase Auth.
VITE_LOCAL_DEVELOPMENT_MODE=false

# Cloudflare R2
R2_ACCOUNT_ID=replace-with-cloudflare-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=meal-ledger-media
R2_PUBLIC_BASE_URL=https://media.example.com

# Optional AI integration
AI_PROVIDER=openai-or-gemini
AI_API_KEY=replace-with-ai-key
